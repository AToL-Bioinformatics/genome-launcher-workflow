profiles {
    pawsey {
        // We normally use the following options for singularity.
        // runOptions = '-B $PWD,$TMPDIR,/scratch -H $(mktemp -d) --pwd $PWD --cleanenv --containall --writable-tmpfs'
        // However they cause an issue for staging the FCSGX DB into ram.
        //TODO: work out how to override this specifically for FCSGX
        singularity {
            enabled = true
            autoMounts = true
            pullTimeout = 60.m
        }

        executor {
            queueSize = 12
        }

        process {
            resourceLimits = [
                memory: 1020.GB,
                cpus: 256,
            ]
            executor = 'slurm'
            module = 'singularity/4.1.0-nohost'
            cache = 'lenient'
            stageInMode = 'symlink'

            // Try to avoid the long queue by redefining the time for jobs that
            // request more than 1.d on the first attempt. Subsequent attempts
            // won't be modified. 
            queue = { task.memory > 235520.MB ? 'highmem' : (task.time > 1.d ? 'long' : null) }

            // Pawsey is giving me error 125 when the OOM killer is active. Try
            // to override the default spec (which is here:
            // https://github.com/sanger-tol/genomeassembly/blob/31b508a3bd8998a27f6d06d5dc41bea4707b4a03/conf/base.config#L18)
            errorStrategy = { task.exitStatus in ((130..145) + 104 + 125) ? 'retry' : 'finish' }

            withName: '.*RUN_NT_KRAKEN.*' {
                memory = { task.attempt * 256.Gb }
                queue = 'highmem'
                time = 3.d
            }

            withName: '.*EXTRACT_NT_BLAST:BLAST_BLASTN.*' {
                memory = { task.attempt * 128.Gb }
                time = 3.d
            }

            withName: '.*:GENOMIC:RUN_READ_COVERAGE:SE_MAPPING:MINIMAP2_ALIGN_SE' {
                cpus = { 20 * 1 }
                memory = {
                    def refSize = reference.size()
                    1.GB * (refSize < 1.5e9
                        ? 30
                        : (refSize < 5e9
                            ? 40
                            : (refSize < 10e9
                                ? 60
                                : Math.ceil(
                                    (refSize / 1e9) * 15
                                )))) * task.attempt
                }
                time = {
                    def refSize = reference.size()
                    1.h * (refSize < 1e9 ? 10 : refSize < 10e9 ? 30 : 48)
                }
            }

            // scratch = '/dev/shm' and stageInMode = 'copy' automatically
            // stage the DB to a ram disk
            withName: FCSGX_RUNGX {
                cpus = { 32 }
                memory = { 520.GB }
                time = { 12.h }
                scratch = '/dev/shm'
                stageInMode = 'copy'
            }
        }

        aws {
            client {
                endpoint = 'https://projects.pawsey.org.au'
                s3PathStyleAccess = true
                maxConnections = 4
                maxErrorRetry = 20
                uploadMaxAttempts = 20
            }
        }
    }
}

// The params block is lifted from 
// https://github.com/sanger-tol/ascc/blob/main/conf/production.config,
// with paths updated for Setonix.
params {
    config_profile_name = 'AToL ASCC Profile'
    config_profile_description = 'Profile for running ASCC on Setonix'

    // all available methods
    // "pca,umap,t-sne,isomap,lle_standard,lle_hessian,lle_modified,mds,se,random_trees,kernel_pca,pca_svd,autoencoder_sigmoid,autoencoder_linear,autoencoder_selu,autoencoder_relu,nmf"

    // Effectively replaces the Static.config
    pacbio_barcode_file = "${projectDir}/assets/ascc_database_fasta/pacbio_adaptors.fa"

    kmer_length = 7
    nt_database_path = "s3://pawsey1132.atol.refdata.v1/ncbi_nucleotide_blast"
    nt_database_prefix = "nt"
    nt_kraken_database_path = "s3://pawsey1132.atol.refdata.kraken/k2_core_nt"
    ncbi_taxonomy_path = "s3://pawsey1132.atol.refdata.v1/taxdump"
    ncbi_ranked_lineage_path = "s3://pawsey1132.atol.refdata.v1/taxdump/rankedlineage.dmp"
    busco_lineages_folder = "/scratch/pawsey1132/atims/busco/"

    // fcs_gx_database_path = "s3://pawsey1132.atol.refdata.fcsgx/fcsgx/"
    vecscreen_database_path = "s3://pawsey1132.atol.refdata.vecscreen/vecscreen/"
    diamond_uniprot_database_path = "s3://pawsey1132.atol.refdata.uniprot.diamond/diamond/reference_proteomes.dmnd"
    diamond_nr_database_path = "s3://pawsey1132.atol.refdata.nr.diamond/diamond/nr.dmnd"
    seqkit_sliding = 100000
    seqkit_window = 6000
    n_neighbours = 13
    filter_cutoff = 1000000000

    // These are the internally agreed upon subworkflows which are used
    // for sanger decontamination.
    run_essentials = "both"
    run_kmers = "off"
    run_tiara = "both"
    run_coverage = "both"
    run_nt_blast = "off"
    run_nr_diamond = "off"
    run_uniprot_diamond = "off"
    run_kraken = "off"
    run_fcsgx = "both"
    run_fcs_adaptor = "both"
    run_vecscreen = "both"
    run_btk_busco = "genomic"
    run_pacbio_barcodes = "both"
    run_organellar_blast = "genomic"
    run_autofilter_assembly = "both"
    run_create_btk_dataset = "both"
    run_merge_datasets = "genomic"
    run_html_report = "both"
    run_decontaminate_fasta = "both"
}
