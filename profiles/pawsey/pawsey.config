// Shared Pawsey Setonix configuration for all sanger-tol/nf-core pipelines
// Usage: -profile singularity,pawsey[,pipeline_name]

// Enable Nextflow lineage tracking
lineage.enabled = true
lineage.store.location = System.getenv('NXF_LINEAGE')

profiles {

    pawsey {

        // Note: it's tempting to use the apptainer profile, but nf-core
        // (and some sanger-tol) pipelines have a conditional
        // `workflow.containerEngine == 'singularity'` that prevents using
        // the right URL with apptainer.
        singularity {
            enabled = true
            autoMounts = true
            pullTimeout = 60.m
            runOptions = '-B $PWD,$TMPDIR,/scratch -H $(mktemp -d) --pwd $PWD --containall --cleanenv --writable-tmpfs'
        }

        // Submit up to 128 concurrent jobs (Setonix work partition max is 256)
        executor {
            queueSize = 128
        }

        process {
            // Setonix highmem nodes have 1020 GB RAM and 256 cores
            resourceLimits = [
                memory: 1020.GB,
                cpus: 256,
            ]
            executor = 'slurm'
            module = 'singularity/4.1.0-nohost'
            cache = 'lenient'
            stageInMode = 'symlink'

            // Queue selection:
            // - highmem: jobs requesting > 230 GB RAM
            // - long: jobs requesting > 1 day runtime
            // - work (default): everything else
            queue = { task.memory > 235520.MB ? 'highmem' : (task.time > 1.d ? 'long' : null) }

            // Pawsey returns exit code 125 when OOM killer is active
            errorStrategy = { task.exitStatus in ((130..145) + 104 + 125) ? 'retry' : 'finish' }

            // nf-core labels (used by sanger-tol pipelines)
            // Standard Setonix nodes: 128 cores, 230 GB RAM (~1840 MB/core)
            withLabel: process_low {
                cpus = { 6 * task.attempt }
                memory = { 12.GB * task.attempt }
            }
            withLabel: process_medium {
                cpus = { 20 * task.attempt }
                memory = { 36.GB * task.attempt }
            }
            withLabel: process_high {
                cpus = { 40 * task.attempt }
                memory = { 72.GB * task.attempt }
            }
            withLabel: process_long {
                time = { 24.h * task.attempt }
            }
            withLabel: process_high_memory {
                memory = { 230.GB * task.attempt }
            }
        }

        aws {
            client {
                endpoint = 'https://projects.pawsey.org.au'
                s3PathStyleAccess = true
                maxConnections = 4
                maxErrorRetry = 20
                uploadMaxAttempts = 20
            }
        }
    }

    // =========================================================================
    // Pipeline-specific profiles
    // =========================================================================

    genomeassembly {

        process {
            // HIFIASM: reduce time/memory to avoid long/highmem queues
            withName: '.*:HIFIASM.*' {
                time = { 6.h * task.attempt }
                memory = { 72.GB * task.attempt }
            }

            // YAHS: allocate full node - fails silently on some assemblies
            withName: 'SANGERTOL_GENOMEASSEMBLY:GENOMEASSEMBLY:SCAFFOLDING:SCAFFOLDING_YAHS:YAHS' {
                memory = { task.attempt == 1 ? 230.GB : null }
            }

            // BUSCO 6: add --tar for output, --offline for local DB.
            // --skip_bbtools is meant to fix
            // https://gitlab.com/ezlab/busco/-/issues/821 and
            // https://gitlab.com/ezlab/busco/-/work_items/841 but it seems you
            // can increase the heap size with the _JAVA_OPTIONS variable (not
            // documented but used by Galaxy, see
            // https://github.com/TomHarrop/tools-iuc/blob/b76fe0b833d61c5161ed033ce1f57e3881bf336f/tools/bbtools/bbmerge.xml#L38)
            // Note - Jim has fixed this in the biocontainer, see
            // https://github.com/bioconda/bioconda-recipes/commit/8d8d85bca6f6b499844185ebaec34255db5698d4
            // and https://github.com/sanger-tol/genomeassembly/pull/130
            withName: '.*BUSCO.*' {
                ext.args = { "--tar --offline" }
                errorStrategy = 'retry'
                maxRetries = 3
                cpus = { 32 * task.attempt }
                memory = { 55.GB * task.attempt }
                time = { 6.h * task.attempt }
                containerOptions = { "--env _JAVA_OPTIONS=-Xmx${task.memory.toGiga()}g" }
            }

            withName: '.*GAWK.*' {
                container = 'docker://quay.io/biocontainers/gawk:5.3.0'
            }

            // JUICERTOOLS_PRE: increase default time for larger assemblies
            withName: '.*JUICERTOOLS_PRE' {
                time = { 12.h * task.attempt }
            }

            // MERQURYFK: increase memory
            withName: '.*MERQURYFK_MERQURYFK' {
                memory = { task.attempt == 1 ? 72.Gb : null }
            }

            // pyfastx 2.2.0 bug fix: use container from 1.0.0
            withName: '.*FASTXALIGN_MINIMAP2ALIGN' {
                container = 'https://community-cr-prod.seqera.io/docker/registry/v2/blobs/sha256/e3/e3e96ee4627b21402c6503d365bdc27e61f3ef5ae6dbeeda02b70a7157f2de9d/data'
            }
            withName: '.*FASTXALIGN_PYFASTXINDEX' {
                container = 'https://community-cr-prod.seqera.io/docker/registry/v2/blobs/sha256/e3/e3e96ee4627b21402c6503d365bdc27e61f3ef5ae6dbeeda02b70a7157f2de9d/data'
            }

            // Reduce times to avoid long queue (defaults are 30-48hr)
            withName: '.*:SCAFFOLDING:SCAFFOLDING_YAHS:YAHS_MAKEPAIRSFILE' {
                time = { 24.h * task.attempt }
            }
            withName: '.*:MITOHIFI_MITOHIFI.*' {
                time = { 24.h * task.attempt }
            }
            withName: '.*:ORGANELLE_ASSEMBLY:OATK' {
                time = { 24.h * task.attempt }
            }
        }
    }

    ascc {

        // FCSGX requires staging DB to RAM disk - can't use full isolation
        singularity {
            runOptions = '-B $PWD,$TMPDIR,/scratch --writable-tmpfs'
        }

        process {
            // Default: apply isolation to all ASCC processes
            containerOptions = '-H $(mktemp -d) --pwd $PWD --containall --cleanenv'

            withName: '.*RUN_NT_KRAKEN.*' {
                memory = { task.attempt * 256.Gb }
                queue = 'highmem'
                time = 3.d
            }

            withName: '.*EXTRACT_NT_BLAST:BLAST_BLASTN.*' {
                memory = { task.attempt * 128.Gb }
                time = 3.d
            }

            withName: '.*:GENOMIC:RUN_READ_COVERAGE:SE_MAPPING:MINIMAP2_ALIGN_SE' {
                cpus = { 20 * 1 }
                memory = {
                    def refSize = reference.size()
                    1.GB * (refSize < 1.5e9
                        ? 30
                        : (refSize < 5e9
                            ? 40
                            : (refSize < 10e9
                                ? 60
                                : Math.ceil((refSize / 1e9) * 15)))) * task.attempt
                }
                time = {
                    def refSize = reference.size()
                    1.h * (refSize < 1e9 ? 10 : refSize < 10e9 ? 30 : 48)
                }
            }

            // FCSGX: stage DB to RAM disk
            withName: FCSGX_RUNGX {
                cpus = { 32 }
                memory = { 520.GB }
                time = { 12.h }
                scratch = '/dev/shm'
                stageInMode = 'copy'
                containerOptions = '-B /dev/shm'
            }

            // SANGER_TOL_BTK: runs nextflow on the host (no container)
            // Try to avoid the long queue on the first attempt
            withName: '.*SANGER_TOL_BTK.*' {
                errorStrategy = 'retry'
                maxRetries = 3
                cpus = { 32 * task.attempt }
                memory = { 55.GB * task.attempt }
                time = { 6.h * task.attempt }
            }
        }
    }
}

treeval {

    process {

        withName: SAMTOOLS_MERGE {
            time = { 12.h * task.attempt }
            cpus = 32
        }

        withName: PRETEXTMAP {
            time = { 12.h * task.attempt }
        }

        withName: PRETEXTMAP_STANDRD {
            time = { 12.h * task.attempt }
        }

        withName: PRETEXTMAP_HIGHRES {
            time = { 12.h * task.attempt }
        }

        withName: '.*GAWK.*' {
            container = 'quay.io/biocontainers/gawk:5.3.0'
        }

        withName: GNU_SORT {
            memory = { task.attempt * 3600.MB }
        }

        withName: '.*GET_PAIRED_CONTACT_BED.*' {
            memory = { task.attempt * 228.GB }
            time = { 12.h * task.attempt }
        }
    }
}
