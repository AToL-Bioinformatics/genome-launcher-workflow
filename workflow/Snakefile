#!/usr/bin/env python3

from functools import cache
from pathlib import Path
import yaml_manifest


configfile: "config/config.yaml"


# setup paths
manifest = yaml_manifest.Manifest.from_yaml(Path(config["manifest"]))


include: "rules/01_functions.smk"
include: "rules/05_globals.smk"
include: "rules/10_assembly_data_downloader.smk"
include: "rules/11_pipeline_result_uploader.smk"
include: "rules/20_pacbio_qc.smk"
include: "rules/21_ont_qc.smk"
include: "rules/25_hic_qc.smk"
include: "rules/29_format_conversions.smk"
include: "rules/30_stage_busco_dataset.smk"
include: "rules/31_stage_s3_bucket.smk"


rule download_reads:
    input:
        manifest.reads.flat_paths("raw"),


rule run_qc:
    input:
        manifest.reads.flat_paths("qc"),


rule pre_genomeassembly:
    input:
        rules.run_qc.input,
        expand(
            rules.expand_busco_lineage_files.output, busco_dataset=odb12_busco_dataset
        ),
        [replace_ext(x, ".fasta.gz") for x in manifest.long_reads.flat_paths("qc")],


rule post_genomeassembly:
    input:
        expand(
            rules.stage_s3_bucket.output.staging_dir,
            bucket_name=["diamond_uniprot_database", "fcsgx", "nt_database"],
        ),
        expand(
            rules.expand_busco_lineage_files.output, busco_dataset=odb10_busco_dataset
        ),
        Path(manifest.get_dir("results"), "upload_receipts", "genomeassembly.jsonl"),


rule post_ascc:
    input:
        Path(manifest.get_dir("results"), "upload_receipts", "ascc.jsonl"),
        [
            yaml_manifest.replace_ext(x, ".fasta.gz")
            for x in manifest.long_reads.flat_paths("qc")
        ],
        manifest.treeval_assembly.outputs_for("ascc").get("COMBINED"),


rule post_treeval:
    input:
        Path(manifest.get_dir("results"), "upload_receipts", "treeval.jsonl"),


rule target:
    default_target: True
    input:
        rules.pre_genomeassembly.input,
