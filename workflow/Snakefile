#!/usr/bin/env python3

import yaml_manifest
from pathlib import Path


def generate_target(wildcards):
    targets = []
    if len(manifest.pacbio_reads) > 0:
        for pb_target in rules.pacbio_qc_target.input:
            targets.append(pb_target)

    if len(manifest.hic_reads) > 0:
        for hic_target in rules.hic_qc_target.input:
            targets.append(hic_target)

    return targets


# setup paths
manifest = yaml_manifest.Manifest.from_yaml(Path(config["manifest"]))


include: "rules/10_assembly_data_downloader.smk"
include: "rules/20_pacbio_qc.smk"
include: "rules/25_hic_qc.smk"


rule target:
    default_target: True
    input:
        generate_target,
